{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "properties": {
    "app": {
      "description": "Application configuration",
      "properties": {
        "name": {
          "description": "Application name",
          "type": "string"
        },
        "replicas": {
          "description": "Replica count",
          "type": "number"
        }
      },
      "type": "object"
    },
    "backend": {
      "description": "Backend configuration",
      "properties": {
        "name": {
          "description": "Backend name",
          "type": "string"
        },
        "replicaCount": {
          "description": "Replica count",
          "type": "number"
        },
        "service": {
          "properties": {
            "port": {
              "type": "number"
            }
          },
          "type": "object"
        }
      },
      "type": "object"
    },
    "network": {
      "properties": {
        "port": {
          "type": "number"
        }
      },
      "type": "object"
    }
  },
  "type": "object"
}