{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["appName", "replicas"],
  "properties": {
    "appName":  { "type": "string", "minLength": 1 },
    "replicas": { "type": "integer", "minimum": 1, "maximum": 10 },
    "enabled":  { "type": "boolean" }
  }
}
