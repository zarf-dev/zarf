---
import Select from "@astrojs/starlight/components/Select.astro";
import versions from "../../versions.json";

// import.meta.env.BASE_URL is "/" for the current build and "/<slug>" (with or
// without a trailing slash) for an archived build (set via DOCS_BASE in
// hack/build-versions.mjs), so normalize before comparing.
const withSlash = (s: string) => (s.endsWith("/") ? s : `${s}/`);
const currentBase = withSlash(import.meta.env.BASE_URL);

const options = [
  { label: "Latest", value: "/" },
  ...versions.versions.map((v) => ({ label: v.label, value: `/${v.slug}/` })),
].map((o) => ({ ...o, selected: withSlash(o.value) === currentBase }));
---

{
  options.length > 1 && (
    <starlight-version-select data-current-base={currentBase}>
      <Select
        icon="open-book"
        label="Select documentation version"
        options={options}
        width="7em"
      />
    </starlight-version-select>
  )
}

<script>
  class StarlightVersionSelect extends HTMLElement {
    constructor() {
      super();
      const select = this.querySelector<HTMLSelectElement>("select");
      if (!select) return;
      // The base of the page being viewed: "/" for Latest, "/<slug>/" for an archive.
      const currentBase = this.dataset.currentBase || "/";

      select.addEventListener("change", () => {
        const targetBase = select.value;
        // Path within the current version, stripped of its base prefix.
        const { pathname, search, hash } = window.location;
        const sub = pathname.startsWith(currentBase)
          ? pathname.slice(currentBase.length)
          : pathname.replace(/^\//, "");
        const targetPath = `${targetBase}${sub}`;

        // Stay on the same page if it exists in the target version; otherwise
        // fall back to that version's home so a switch never lands on a 404.
        fetch(targetPath, { method: "HEAD" })
          .then((res) => {
            window.location.href = res.ok ? `${targetPath}${search}${hash}` : targetBase;
          })
          .catch(() => {
            window.location.href = targetBase;
          });
      });
    }
  }
  customElements.define("starlight-version-select", StarlightVersionSelect);
</script>
